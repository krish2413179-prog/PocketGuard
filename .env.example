# ── AI ────────────────────────────────────────────────────────────────────────
# Venice AI API key (https://venice.ai)
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=llama-3.3-70b

# ── 1Shot Gasless Relayer ─────────────────────────────────────────────────────
# https://1shotapi.com — leave ONESHOT_API_KEY blank for public testnet relayer
ONESHOT_RPC_URL=https://api.1shotapi.com/v1/rpc
ONESHOT_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# The public URL of your deployment (used for CORS, Snap fetches etc.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_CHAIN_ID=421614

# ── Vercel KV (Upstash Redis) — REQUIRED on Vercel ───────────────────────────
# Create a KV database in your Vercel project dashboard and paste the auto-filled values:
# https://vercel.com/docs/storage/vercel-kv/quickstart
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Venice x402 (optional) ────────────────────────────────────────────────────
# A throwaway EVM wallet private key used for x402 micro-payments to Venice AI.
# NOT your main wallet. Generate at https://vanity-eth.tk/ or similar.
VENICE_X402_PRIVATE_KEY=
